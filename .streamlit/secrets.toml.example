# .streamlit/secrets.toml.example
# Copy this to .streamlit/secrets.toml for local use,
# OR paste the values into Streamlit Community Cloud's
# "Secrets" section (App settings → Secrets).

# URL of your deployed Render API
API_BASE_URL = "https://your-app-name.onrender.com"

# Must match the API_KEY set on Render
API_KEY = "your-api-key-here"
