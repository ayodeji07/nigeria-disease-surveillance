# ─────────────────────────────────────────────────────────────
# Environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# For local PostgreSQL:
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nigeria_health
# For Supabase (production):
#   DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# For SQLite (testing only — no PostGIS support):
#   DATABASE_URL=sqlite:///./nigeria_health.db
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nigeria_health

# ── API security ──────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secret-api-key-here

# ── Notification (optional — used by GitHub Actions ETL) ──────
NOTIFY_EMAIL=your@email.com
SENDGRID_API_KEY=your-sendgrid-key-here

# ── Application settings ──────────────────────────────────────
# Set to "development" locally, "production" on Render/cloud
APP_ENV=development
LOG_LEVEL=INFO

# ── Dashboard settings ────────────────────────────────────────
# URL of your running FastAPI service
# Locally: http://localhost:8000
# Production: https://nigeria-health-api.onrender.com
API_BASE_URL=http://localhost:8000
